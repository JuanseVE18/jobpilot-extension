{
  "manifest_version": 3,
  "name": "JobPilot – Smart Job Autofill",
  "short_name": "JobPilot",
  "version": "1.0",
  "description": "Autofills job applications",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["<all_urls>"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  }
}